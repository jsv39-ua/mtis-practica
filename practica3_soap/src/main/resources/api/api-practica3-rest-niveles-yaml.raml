#%RAML 1.0
types:
  DispositivoInput:
    description: Datos de entrada para crear o modificar un dispositivo
    type: object
    example:
      strict: false
      value:
        codigo: 301
        descripcion: Terminal lector de tarjeta ubicado en la entrada norte
    properties:
      codigo:
        description: Código del dispositivo
        example:
          strict: false
          value: 301
        type: number
        format: int32
        required: true
      descripcion?:
        description: Descripción del dispositivo
        example:
          strict: false
          value: Terminal lector de tarjeta ubicado en la entrada norte
        type: string
  NotificacionUsuarioValidoInput:
    description: Datos de entrada para notificar a un empleado si es válido
    type: object
    example:
      strict: false
      value:
        nifnie: 33900165M
    properties:
      nifnie:
        description: NIF/NIE del empleado a notificar
        example:
          strict: false
          value: 33900165M
        type: string
        required: true
  Error:
