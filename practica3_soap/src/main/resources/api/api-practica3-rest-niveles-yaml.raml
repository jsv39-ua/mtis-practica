        example:
          strict: false
          value: Recurso no encontrado
        type: string
      mensajeDetalle?:
        description: Descripción detallada del error producido
        example:
          strict: false
          value: No se ha encontrado ninguna sala con el código 101 en la base de datos
        type: string
  Sala:
    description: Estructura completa de una sala del edificio inteligente
    type: object
    example:
      strict: false
      value:
        codigoSala: 101
        nombre: Sala de Reuniones A
        nivel: 2
        mensajeDetalle: Operación realizada correctamente
    properties:
      codigoSala:
        description: Código único de la sala
        example:
          strict: false
          value: 101
        type: number
        format: int32
        required: true
      nombre:
        description: Nombre descriptivo de la sala
        example:
          strict: false
          value: Sala de Reuniones A
        type: string
        required: true
      nivel:
        description: Nivel de seguridad requerido para acceder a la sala
        example:
          strict: false
          value: 2
        type: number
        format: int32
        required: true
      mensajeDetalle?:
        description: Mensaje detallado con información adicional o errores producidos
        example:
          strict: false
          value: Operación realizada correctamente
        type: string
  RespuestaCreacion:
    description: Respuesta estándar para operaciones de creación
    type: object
    example:
      strict: false
      value:
        id: 101
        mensaje: Recurso creado correctamente
        mensajeDetalle: El registro ha sido insertado en la base de datos correctamente
    properties:
      id?:
        description: Identificador del recurso creado
        example:
          strict: false
          value: 101
        type: number
        format: int32
      mensaje?:
        description: Mensaje descriptivo del resultado de la operación
        example:
          strict: false
          value: Recurso creado correctamente
        type: string
      mensajeDetalle?:
        description: Mensaje detallado con información adicional sobre la operación
        example:
          strict: false
          value: El registro ha sido insertado en la base de datos correctamente
        type: string
  SalaInput:
    description: Datos de entrada para crear o modificar una sala
    type: object
    example:
      strict: false
      value:
        codigoSala: 101
        nombre: Sala de Reuniones A
        nivel: 2
    properties:
      codigoSala:
        description: Código único de la sala
        example:
          strict: false
          value: 101
        type: number
        format: int32
        required: true
      nombre:
        description: Nombre descriptivo de la sala
        example:
          strict: false
          value: Sala de Reuniones A
        type: string
        required: true
      nivel:
        description: Nivel de seguridad requerido para acceder a la sala
        example:
          strict: false
          value: 2
        type: number
        format: int32
        required: true
  RespuestaOperacion:
    description: Respuesta estándar para operaciones de modificación y eliminación
    type: object
    example:
      strict: false
      value:
        exito: true
        mensaje: Operación realizada correctamente
        mensajeDetalle: El registro ha sido actualizado en la base de datos correctamente
    properties:
      exito?:
        description: Indica si la operación se realizó correctamente
        example:
          strict: false
          value: true
        type: boolean
      mensaje?:
        description: Mensaje descriptivo del resultado de la operación
        example:
          strict: false
          value: Operación realizada correctamente
        type: string
      mensajeDetalle?:
        description: Mensaje detallado con información adicional o errores producidos
        example:
          strict: false
          value: El registro ha sido actualizado en la base de datos correctamente
        type: string
  NotificacionPresenciaSalaInput:
    description: |
      Datos de entrada para notificar por email a los empleados presentes en una sala
    type: object
    example:
      strict: false
      value:
        codigoSala: 101
    properties:
      codigoSala:
        description: Código de la sala cuyos empleados presentes serán notificados
        example:
          strict: false
          value: 101
        type: number
        format: int32
        required: true
  Dispositivo:
    description: Estructura completa de un dispositivo de control del edificio
    type: object
    example:
      strict: false
      value:
        codigo: 301
        descripcion: Terminal lector de tarjeta ubicado en la entrada norte
        mensajeDetalle: Operación realizada correctamente
    properties:
      codigo:
        description: Código único del dispositivo
        example:
          strict: false
          value: 301
        type: number
        format: int32
        required: true
      descripcion?:
        description: Descripción del dispositivo
        example:
          strict: false
          value: Terminal lector de tarjeta ubicado en la entrada norte
        type: string
      mensajeDetalle?:
        description: Mensaje detallado con información adicional o errores producidos
        example:
          strict: false
          value: Operación realizada correctamente
        type: string
  Nivel:
    description: Estructura completa de un nivel de seguridad
    type: object
    example:
      strict: false
      value:
        nivel: 2
        descripcion: Acceso restringido a empleados con perfil intermedio
        mensajeDetalle: Operación realizada correctamente
    properties:
      nivel:
        description: Identificador del nivel de seguridad
        example:
          strict: false
          value: 2
        type: number
        format: int32
        required: true
      descripcion?:
        description: Descripción del nivel de seguridad
        example:
          strict: false
          value: Acceso restringido a empleados con perfil intermedio
        type: string
      mensajeDetalle?:
        description: Mensaje detallado con información adicional o errores producidos
        example:
          strict: false
          value: Operación realizada correctamente
        type: string
  RespuestaNotificacion:
    description: Respuesta estándar para operaciones de notificación por email
    type: object
    example:
      strict: false
      value:
        emailsEnviados: 3
        mensaje: Notificaciones enviadas correctamente
        mensajeDetalle: Se han enviado 3 notificaciones por email a los empleados presentes
    properties:
      emailsEnviados?:
        description: Número de emails enviados correctamente
        example:
          strict: false
          value: 3
        type: number
        format: int32
      mensaje?:
        description: Mensaje descriptivo del resultado de la operación
        example:
          strict: false
          value: Notificaciones enviadas correctamente
        type: string
      mensajeDetalle?:
        description: Mensaje detallado con información adicional o errores producidos
        example:
          strict: false
          value: Se han enviado 3 notificaciones por email a los empleados presentes
        type: string
  NotificacionErrorInput:
    description: Datos de entrada para notificar un error a un empleado
    type: object
    example:
      strict: false
      value:
        nifnie: 33900165M
        error: Error de acceso a la sala 101, credenciales caducadas
    properties:
      nifnie:
        description: NIF/NIE del empleado al que se le notificará el error
        example:
          strict: false
          value: 33900165M
        type: string
        required: true
      error:
        description: Descripción del error a notificar
        example:
          strict: false
          value: Error de acceso a la sala 101, credenciales caducadas
        type: string
        required: true
  NivelInput:
    description: Datos de entrada para crear o modificar un nivel de seguridad
    type: object
    example:
      strict: false
      value:
        nivel: 2
        descripcion: Acceso restringido a empleados con perfil intermedio
    properties:
      nivel:
        description: Identificador del nivel de seguridad
        example:
          strict: false
          value: 2
        type: number
        format: int32
        required: true
      descripcion?:
        description: Descripción del nivel de seguridad
        example:
          strict: false
          value: Acceso restringido a empleados con perfil intermedio
        type: string
