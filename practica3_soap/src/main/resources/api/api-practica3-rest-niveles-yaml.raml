      generated_2:
        strict: false
        value:
          codigo: 400
          mensaje: Datos de entrada incorrectos
          mensajeDetalle: El campo 'nombre' es obligatorio y no puede estar vacío
      generated_3:
        strict: false
        value:
          codigo: 401
          mensaje: No autorizado
          mensajeDetalle: La WSKey proporcionada no existe en la base de datos
      generated_4:
        strict: false
