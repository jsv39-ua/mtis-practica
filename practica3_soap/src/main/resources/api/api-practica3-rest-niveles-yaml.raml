title: Edificio Inteligente API
baseUri: http://localhost:8081/api/v1
(amf-serverDescription): Servidor principal Edificio Inteligente
description: |
  API REST para la gestión de un edificio inteligente. Proporciona servicios para la gestión de salas, niveles de seguridad, dispositivos de control y notificaciones por email.
version: 1.0.0
(amf-contact):
  email: info@edificiointeligente.org
(amf-tags):
  -
    name: salas
    description: Gestión de salas del edificio
  -
    name: niveles
    description: Gestión de niveles de seguridad
  -
    name: dispositivos
    description: Gestión de dispositivos de control
  -
    name: notificaciones
    description: Servicio de notificaciones por email
(amf-license):
  url: http://www.apache.org/licenses/LICENSE-2.0.html
  name: Apache 2.0
/salas:
  post:
    displayName: salasPOST
    description: Crea una nueva sala en la base de datos a partir de la estructura indicada.
    (amf-summary): Crear nueva sala
    (amf-tags):
      - salas
    queryParameters:
      WSKey:
        description: |
          Clave de autenticación del servicio web. Debe existir en la base de datos para que la operación sea ejecutada.
        required: false
        type: string
    body:
      application/json: SalaInput
    responses:
      "201":
        description: Sala creada correctamente
        body:
          application/json: RespuestaCreacion
      "400":
        description: Datos de entrada incorrectos
        body:
          application/json: Error
      "401":
        description: WSKey no válida
        body:
          application/json: Error
      "409":
        description: La sala ya existe
        body:
          application/json: Error
    (codegen-request-body-name): salaInput
    (eov-operation-handler): controllers/SalasController
/salas/{id}:
  delete:
    displayName: salasIdDELETE
    description: Elimina de la base de datos el registro de la sala indicada por su identificador (clave primaria).
    (amf-summary): Borrar sala
    (amf-tags):
      - salas
    queryParameters:
      WSKey:
        description: |
          Clave de autenticación del servicio web. Debe existir en la base de datos para que la operación sea ejecutada.
        required: false
        type: string
    (amf-baseUriParameters):
      id:
        description: Identificador único (PK) de la sala
        required: true
        type: number
        format: int32
    responses:
      "200":
        description: Sala eliminada correctamente
        body:
          application/json: RespuestaOperacion
      "401":
        description: WSKey no válida
        body:
          application/json: Error
      "404":
        description: Sala no encontrada
        body:
          application/json: Error
    (eov-operation-handler): controllers/SalasController
  get:
    displayName: salasIdGET
    description: Devuelve la estructura completa de una sala a partir de su identificador (clave primaria).
    (amf-summary): Consultar sala
    (amf-tags):
      - salas
    queryParameters:
      WSKey:
        description: |
          Clave de autenticación del servicio web. Debe existir en la base de datos para que la operación sea ejecutada.
        required: false
        type: string
    (amf-baseUriParameters):
      id:
        description: Identificador único (PK) de la sala
        required: true
        type: number
        format: int32
    responses:
      "200":
        description: Sala encontrada correctamente
        body:
          application/json: Sala
      "400":
        description: Parámetros de entrada incorrectos
        body:
          application/json: Error
      "401":
        description: WSKey no válida
        body:
          application/json: Error
      "404":
        description: Sala no encontrada
        body:
          application/json: Error
    (eov-operation-handler): controllers/SalasController
  put:
    displayName: salasIdPUT
    description: |
      Actualiza en la base de datos el registro de una sala. Se pasa la estructura completa y devuelve un código de estado indicando si la actualización fue correcta.
    (amf-summary): Modificar sala
    (amf-tags):
      - salas
    queryParameters:
      WSKey:
        description: |
          Clave de autenticación del servicio web. Debe existir en la base de datos para que la operación sea ejecutada.
        required: false
        type: string
    body:
      application/json: SalaInput
    (amf-baseUriParameters):
      id:
        description: Identificador único (PK) de la sala
        required: true
        type: number
        format: int32
    responses:
      "200":
        description: Sala actualizada correctamente
        body:
          application/json: RespuestaOperacion
      "400":
        description: Datos de entrada incorrectos
        body:
          application/json: Error
      "401":
        description: WSKey no válida
        body:
          application/json: Error
      "404":
        description: Sala no encontrada
        body:
          application/json: Error
    (codegen-request-body-name): salaInput
    (eov-operation-handler): controllers/SalasController
/niveles:
  post:
    displayName: nivelesPOST
